# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Enable local mode (skips AWS DynamoDB + Step Functions callbacks)
LOCAL_MODE=true

# Portal credentials
APP_USERNAME=john.doe
APP_PASSWORD=user123

# Portal URL
PORTAL_BASE_URL=https://vb-bank-demo.vercel.app/login

# Optional: override task input (JSON string)
# LOCAL_TASK_JSON={"task_id":"local-vb","payload":{"portal":"vb_bank","username":"john.doe","account_name":"John Doe","s3_prefix":"vb/local"}}

# Optional: override output directory (default: /tmp/automation-output)
# LOCAL_OUTPUT_DIR=/tmp/automation-output

# Optional: run headless locally (default: false in LOCAL_MODE)
# HEADLESS=true
